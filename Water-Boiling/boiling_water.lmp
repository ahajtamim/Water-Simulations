#Boiling Water

#Initialization
units real
dimension 3 # 3D
atom_style full
boundary p p p

#System definition
region box block -20 20 -20 20 -20 40
create_box 2 box bond/types 1 angle/types 1 extra/bond/per/atom 2 extra/angle/per/atom 1 extra/special/per/atom 2

#Settings
molecule H2O tip3p.mol
region liquid block -15 15 -15 15 -20 0

mass 1 15.9994
mass 2 1.008

pair_style lj/cut/coul/long 8 #LJ + long-range Coulomb
pair_coeff 1 1 0.1550 3.1536 # Sets LJ values epsilon, sigma for O-O
pair_coeff 2 2 0.0 1.0 # Sets LJ values epsilon, sigma for H-H
pair_coeff 1 2 0.0 0.0 # Sets LJ values epsilon, sigma for O-H
kspace_style pppm 1.0e-4 #coulomb interactions beyond the cutoff
special_bonds lj/coul 0.0 0.0 0.0

bond_style harmonic
bond_coeff 1 450.0 0.9572 #(1 = bond type) (450.0 = k [force constant]) (0.9572 = bond length)
angle_style harmonic
angle_coeff 1 55.0 104.52 #(1 = bond type) (55.0 = k [force constant]) (104.52 = angle)

create_atoms 0 random 80 12345 liquid mol H2O 12346 overlap 1.5 maxtry 200

#Monitoring
reset_timestep 0
velocity all create 300.0 12345 mom yes rot yes  #(mom yes - removes net linear momentum) (rot yes - removes net rotation) 
fix 1 all shake 0.0001 20 1000 b 1 a 1
fix 2 all nvt temp 300.0 600.0 100.0

thermo 200
thermo_style custom step temp etotal vol density

dump traj all atom 100 dump_boiling_water.lammpstrj

#Run
timestep 1.0
run 20000

write_data water_boiling.data nocoeff
